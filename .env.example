# Django settings
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Site URL (no trailing slash) - used in templates for API examples and public URLs
SITE_URL=http://localhost:8000
# For production: SITE_URL=https://scores.example.com

# Passkeys / WebAuthn (optional - sensible defaults are derived from SITE_URL)
# WEBAUTHN_RP_ID must be the registrable domain with no scheme or port, e.g. scores.example.com
# WEBAUTHN_RP_ID=localhost
# WEBAUTHN_RP_NAME=Scores
# WEBAUTHN_ORIGIN=http://localhost:8000

# Database settings
DB_NAME=scores
DB_USER=scores
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Email settings (for production, use a real email service)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@example.com
# EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=noreply@localhost
